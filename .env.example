# Application Port
PORT=5000

# PostgreSQL Connection String (e.g., Local PostgreSQL or NeonDB)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=[require|disable]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devpulse?sslmode=disable

# JWT Secret Key (Should be a long, complex, random string in production)
JWT_SECRET=your_jwt_secret_key_here

# JWT Expiration Time (e.g., 1h, 7d, 24h)
JWT_EXPIRES_IN=7d
